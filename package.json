{
  "name": "url_shortener",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "description": "Link shortener dummy project",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.ts\"",
    "clean": "turbo run clean"
  },
  "repository": {

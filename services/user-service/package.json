{
  "name": "@url-shortener/user-service",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@url-shortener/common": "*",
    "@url-shortener/config": "*",
    "@url-shortener/logger": "*",
    "express": "^5.2.1",
    "mongoose": "^9.3.1"
  },
  "devDependencies": {
    "@types/express": "*",
    "@types/node": "*",
    "rimraf": "^5.0.0",
    "ts-node-dev": "*",
    "typescript": "*"
  }
}
